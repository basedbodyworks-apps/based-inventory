# Shopify
# Client Credentials Grant: the app POSTs these to
# /admin/oauth/access_token at the start of each cron run to get a 24h token.
SHOPIFY_STORE=basedbodyworks.myshopify.com
SHOPIFY_CLIENT_ID=replace_me
SHOPIFY_CLIENT_SECRET=shpss_replace_me
SHOPIFY_API_VERSION=2026-01

# Slack
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_CHANNEL=C0AK6UGA1NJ

# Telegram fallback (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime
DRY_RUN=1
ENV=dev
# STATE_PATH can be a local filesystem path OR a redis:// URL.
# Local dev uses a JSON file; Render production uses a Key Value service.
STATE_PATH=./data/alert-state.json
LOG_LEVEL=INFO
